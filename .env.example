# Copy to .env and fill in real values

# Database - Supabase Postgres
# Get the connection string from Supabase dashboard:
#   Project settings → Database → Connection string → "URI"
# Use the "Transaction" pooler URL (port 6543) for serverless runtime,
# and keep the "Session" / direct URL (port 5432) handy for migrations.
DATABASE_URL=""

# Ticketmaster Discovery API
# Register free at https://developer.ticketmaster.com/
TICKETMASTER_API_KEY=""

# Optional - Spotify for artist enrichment (monthly listeners, genres)
# Register free at https://developer.spotify.com/
SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""

# Optional - SeatGeek for live resale pricing
# Register free at https://developer.seatgeek.com/
SEATGEEK_CLIENT_ID=""

# Scraper config
SCRAPE_USER_AGENT="ticket-flip-calendar/0.1 (personal project)"
SCRAPE_REQUEST_DELAY_MS="1500"
